model Customer {
    id        String  @id @default(uuid())
    name      String
    email     String? @unique
    phone     String  @unique @db.VarChar(25)
    address   String? @db.VarChar(250)
    referrer  String?
    shop_type String
    status    Boolean @default(true)
    invoices  Invoice[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers")
}
