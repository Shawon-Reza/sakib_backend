{
  "compilerOptions": {
    // File Layout
    "rootDir": ".",
    "outDir": "./dist",

    // Module / Environment
    "module": "ESNext",
    "target": "ES2023",
    "moduleResolution": "bundler",
    "esModuleInterop": true,

    // Node.js specific
    "lib": ["ES2023"],
    "types": ["node"],

    // Output
    "sourceMap": true,
    "declaration": false,           // Usually not needed for backend
    "declarationMap": false,

    // Strictness (highly recommended)
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Modern TypeScript features
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Remove these if you're not using React in backend
    "jsx": "react-jsx"   // ← Comment out or remove for pure backend
  },

  // Important: Add these at the root level
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}